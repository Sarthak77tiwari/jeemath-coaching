<style>
  :root{
    --primary:#5b3df0;
    --primary-dark:#4527d1;
    --primary-light:#efe9ff;
    --accent:#f5a524;
    --accent-dark:#d98a0c;
    --ink:#1b1730;
    --ink-soft:#4a4560;
    --bg:#ffffff;
    --bg-soft:#f7f6fc;
    --border:#e6e2f7;
    --success:#1c9c6e;
    --radius-lg:20px;
    --radius-md:14px;
    --radius-sm:8px;
    --shadow-soft:0 10px 30px rgba(56,32,140,0.10);
    --shadow-strong:0 18px 45px rgba(56,32,140,0.18);
